#!/bin/bash
set -u

# omarchy-screen-toolkit: extract a small palette from a screen region.
# Selects a region with slurp (with hyprpicker freezing the screen), reduces
# the captured image to N dominant colors via ImageMagick, copies the hex
# list to the clipboard, and writes the result to a runtime sentinel so the
# bar widget can mirror it into paletteHistory.

RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/omarchy-screen-toolkit"
mkdir -p "$RUNTIME_DIR"

# A second invocation while a region picker is still active cancels everything.
if pkill -x slurp 2>/dev/null; then exit 0; fi

PALETTE_N="${OST_PALETTE_N:-6}"

# Freeze the screen so the captured region matches what slurp shows.
hyprpicker -r -z >/dev/null 2>&1 &
PICKER_PID=$!
trap '[[ -n ${PICKER_PID:-} ]] && kill "$PICKER_PID" 2>/dev/null; rm -f "${TMP:-}"' EXIT
sleep 0.1

SELECTION=$(slurp 2>/dev/null) || exit 0
[[ -z $SELECTION ]] && exit 0

TMP=$(mktemp --suffix=.png) || exit 1
grim -g "$SELECTION" "$TMP" || exit 1

# +dither keeps the reduction crisp (no fake mid-tones), -resize bounds work,
# -unique-colors emits one pixel per palette entry which we then read out via
# the histogram formatter. Anything ImageMagick can't read is silently skipped.
COLORS=$(magick "$TMP" -resize 320x320\> +dither -colors "$PALETTE_N" -unique-colors \
  -depth 8 -format "%c" histogram:info:- 2>/dev/null \
  | grep -oE '#[0-9A-Fa-f]{6}' \
  | tr 'A-F' 'a-f' \
  | head -n "$PALETTE_N")

[[ -z $COLORS ]] && exit 1

printf '%s' "$COLORS" | wl-copy
printf '%s\n' "$COLORS" >"$RUNTIME_DIR/palette.last"

COUNT=$(echo "$COLORS" | wc -l | tr -d ' ')
FIRST=$(echo "$COLORS" | head -1)
if command -v omarchy-notification-send >/dev/null 2>&1; then
  omarchy-notification-send -g "$FIRST" "Palette ($COUNT colors)" "$(echo "$COLORS" | tr '\n' ' ')" -t 4000
else
  notify-send -a omarchy-screen-toolkit "Palette ($COUNT colors)" "$(echo "$COLORS" | tr '\n' ' ')" -t 4000
fi
